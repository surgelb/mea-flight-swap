# Supabase Project Config
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter Configuration for PDF parsing and FTL verification
# Replace with your OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Analytics & Rankings headers (Optional but Recommended)
# Set these to your production URL and title to enable ranking on openrouter.ai/rankings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_TITLE="MEA Flight Swap"
